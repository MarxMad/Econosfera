# -----------------------------------------------------------------------------
# ECONOSFERA - Archivo de configuración de ejemplo (.env.example)
# Renombra este archivo a .env y completa las claves correspondientes.
# -----------------------------------------------------------------------------

# --- BASE DE DATOS (Supabase / Postgres) ---
# DATABASE_URL: URL para conexión normal (puerto 6543 para pooling)
# DIRECT_URL: URL para migraciones directas (npx prisma db push)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- AUTENTICACIÓN (NextAuth.js) ---
# NEXTAUTH_URL: URL base de la app. En local: http://localhost:3000
# NEXTAUTH_SECRET: Genera uno con: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="tu_secreto_aqui_aleatorio"
# DEBUG_AUTH=1  # Muestra el error real en respuestas 500 (solo para depurar)

# --- GOOGLE OAUTH (Cloud Console) ---
# Consíguelas en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="tu_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu_google_client_secret"
# Muestra el botón "Iniciar con Google" en login/registro. Pon "true" cuando tengas las credenciales y la URI de redirección configurada (ver docs/GOOGLE_OAUTH_SETUP.md).
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="false"

# --- INTELIGENCIA ARTIFICIAL (OpenAI) ---
# Necesaria para el análisis de minutas de Banxico y reportes económicos
OPENAI_API_KEY="sk-..."

# --- ENVÍO DE CORREOS (Resend) ---
# Consíguela en: https://resend.com
RESEND_API_KEY="re_..."

# --- PAGOS Y SUSCRIPCIONES (Stripe) ---
# Consíguelas en: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs de tus productos (Stripe Dashboard → Productos → copia el ID del precio)
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_RESEARCHER="price_..."
# Webhook: en local usa el de Stripe CLI (stripe listen). En prod, el de Stripe Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Opcional: período de prueba en días
# STRIPE_TRIAL_DAYS="7"

# --- CRON / ADMIN (opcional) ---
# CRON_SECRET: para proteger /api/cron/* y /api/admin/*. Genera uno: openssl rand -hex 32
# CRON_SECRET="..."
# ADMIN_SECRET: alternativo para rutas admin (send-blog-email, send-promo-email)

# --- CONFIGURACIÓN DEL SITIO ---
# Usada para generar enlaces absolutos en correos y metadatos SEO
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- PUBLICIDAD (Google AdSense) - Opcional ---
# Activa anuncios y añade tu ID de editor. Crea unidades de anuncio en AdSense y usa sus slot IDs aquí.
NEXT_PUBLIC_ADS_ENABLED="false"
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-..."
# Slots para las páginas individuales del glosario (opcional; si no se definen, se puede mostrar banner de referido)
NEXT_PUBLIC_ADSENSE_SLOT_GLOSARIO_1=""
NEXT_PUBLIC_ADSENSE_SLOT_GLOSARIO_2=""

# --- PUBLICIDAD REFERIDO (Broker / afiliados) - Opcional ---
# Si AdSense no está activo o no hay slot en una posición, se muestra este banner con tu link de referido.
NEXT_PUBLIC_AFFILIATE_ENABLED="false"
NEXT_PUBLIC_AFFILIATE_BROKER_NAME="Nombre del broker"
NEXT_PUBLIC_AFFILIATE_BROKER_URL="https://..."
NEXT_PUBLIC_AFFILIATE_CTA_TEXT="Abre tu cuenta"
# URL de la imagen del broker (opcional; si no se define, se muestra la inicial del nombre)
NEXT_PUBLIC_AFFILIATE_BROKER_IMAGE=""
